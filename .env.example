# ─── Exemplo de variáveis de ambiente ───
# Copie para .env e ajuste. NÃO comite o .env com valores reais.

# Banco de dados
DB_URL=jdbc:postgresql://localhost:5432/oficina
DB_USER=oficina
DB_PASSWORD=oficina

# Segurança
JWT_SECRET=troque-por-uma-chave-forte-com-no-minimo-32-caracteres
ADMIN_EMAIL=admin@oficina.local
ADMIN_PASSWORD=admin123

# ─── Notificação de status da OS por e-mail ───
# tipo=log (default): apenas registra no log (sem servidor de e-mail).
# tipo=smtp: envia e-mail real usando as variáveis MAIL_* abaixo.
NOTIFICACAO_TIPO=log
NOTIFICACAO_REMETENTE=nao-responder@oficina.local

# Credenciais SMTP (usadas só quando NOTIFICACAO_TIPO=smtp).
# Exemplo com Mailtrap (sandbox para demonstração):
#   MAIL_HOST=sandbox.smtp.mailtrap.io
#   MAIL_PORT=587
#   MAIL_USERNAME=<seu-usuario-do-inbox-mailtrap>
#   MAIL_PASSWORD=<sua-senha-do-inbox-mailtrap>
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
